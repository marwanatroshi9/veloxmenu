# Root environment for docker-compose. Copy to `.env`.

# --- Postgres ---
POSTGRES_USER=menuhub
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=menuhub

# --- Frontend build/runtime ---
# When served through the bundled Nginx proxy, the API is reachable at /api/v1.
NEXT_PUBLIC_API_URL=http://localhost/api/v1
