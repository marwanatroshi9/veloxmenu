# --- Application ---
PROJECT_NAME=MenuHub
ENVIRONMENT=development
DEBUG=false

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-secret-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# In production set COOKIE_SECURE=true and serve over HTTPS.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=.yourdomain.com

# --- CORS (comma-separated origins) ---
BACKEND_CORS_ORIGINS=http://localhost:3000

# --- Database ---
DATABASE_URL=postgresql+psycopg://menuhub:menuhub@db:5432/menuhub

# --- Cloudinary (optional; image upload disabled if unset) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=menuhub

# --- Public site ---
PUBLIC_SITE_URL=http://localhost:3000

# --- Rate limiting ---
RATE_LIMIT_DEFAULT=200/minute
RATE_LIMIT_AUTH=10/minute

# --- Bootstrap super admin (seed script) ---
FIRST_SUPERADMIN_EMAIL=admin@menuhub.app
FIRST_SUPERADMIN_PASSWORD=ChangeMe123!
